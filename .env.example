# BlastRadius — Environment Variables Template
# ──────────────────────────────────────────────────────────
# Copy this file to .env (one level UP from the repo root, or
# inside the repo root — both locations are picked up) and
# fill in your values. .env is gitignored.
#
# For HF Jobs / remote A100 runs, set these as Job secrets
# in the HuggingFace Job UI instead — the notebook reads them
# from os.environ either way.
# ──────────────────────────────────────────────────────────

# ─── Inference API (for inference.py / orchestrator demo) ─
API_BASE_URL=https://integrate.api.nvidia.com/v1
MODEL_NAME=meta/llama-3.1-8b-instruct
OPENAI_API_KEY=nvapi-your-key-here

# ─── Environment URL ──────────────────────────────────────
ENV_BASE_URL=http://localhost:7860

# ─── HuggingFace Deployment (Hub checkpoint pushes) ──────
# Token must have WRITE scope to the HUB_MODEL_ID repo.
HF_TOKEN=hf_your-token-here
HUB_MODEL_ID=your-username/BlastRadius-GRPO-Checkpoints

# ─── Weights & Biases (GRPO training observability) ──────
WANDB_API_KEY=wandb_v1_your-key-here
WANDB_ENTITY=your-wandb-team-or-username
WANDB_PROJECT=blastradius-grpo
